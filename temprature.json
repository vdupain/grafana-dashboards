                      "spec": {
                        "editorMode": "code",
                        "expr": "node_hwmon_temp_max_celsius{instance=~\"$instance\"}\r\n  * on(instance,chip,sensor) group_left(label) node_hwmon_sensor_label \r\n  * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n  or label_replace(node_hwmon_temp_max_celsius{instance=~\"$instance\"}, \"label\", \"$0\", \"sensor\", \".*\") \r\n    * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n    unless on(instance,chip,sensor) node_hwmon_sensor_label",
                        "instant": false,
                        "legendFormat": "Max  {{ chip_name }}/{{ label }}",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "E"
                  }
                }
