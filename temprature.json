      "panel-5": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "bfptkyuoaiakgb"
                      },
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "# The nicest possible display of a metric...\r\nnode_hwmon_temp_celsius{instance=~\"$instance\"} \r\n  * on(instance,chip,sensor) group_left(label) node_hwmon_sensor_label \r\n  * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n# ...but it may filter out metrics that do not have a label, so as a fallback use the machine sensor name\r\n  or on(instance,chip,sensor) label_replace(node_hwmon_temp_celsius{instance=~\"$instance\"}, \"label\", \"$0\", \"sensor\", \".*\") \r\n    * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n  or on(instance,chip,sensor) label_replace(label_replace(node_hwmon_temp_celsius{instance=~\"$instance\"}, \"label\", \"$0\", \"sensor\", \".*\"), \"chip_name\", \"$0\", \"chip\", \".*\")",
                        "legendFormat": "{{chip_name}}/{{label}}",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "bfptkyuoaiakgb"
                      },
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "node_hwmon_temp_crit_alarm_celsius{instance=~\"$instance\"}\r\n  * on(instance,chip,sensor) group_left(label) node_hwmon_sensor_label \r\n  * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n  or label_replace(node_hwmon_temp_crit_alarm_celsius{instance=~\"$instance\"}, \"label\", \"$0\", \"sensor\", \".*\") \r\n    * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n    unless on(instance,chip,sensor) node_hwmon_sensor_label",
                        "instant": false,
                        "legendFormat": "Critical Alarm {{ chip_name }}/{{ label }}",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "B"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "bfptkyuoaiakgb"
                      },
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "node_hwmon_temp_crit_celsius{instance=~\"$instance\"}\r\n  * on(instance,chip,sensor) group_left(label) node_hwmon_sensor_label \r\n  * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n  or label_replace(node_hwmon_temp_crit_celsius{instance=~\"$instance\"}, \"label\", \"$0\", \"sensor\", \".*\") \r\n    * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n    unless on(instance,chip,sensor) node_hwmon_sensor_label",
                        "instant": false,
                        "legendFormat": "Critical  {{ chip_name }}/{{ label }}",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "C"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "bfptkyuoaiakgb"
                      },
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "node_hwmon_temp_crit_hyst_celsius{instance=~\"$instance\"}\r\n  * on(instance,chip,sensor) group_left(label) node_hwmon_sensor_label \r\n  * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n  or label_replace(node_hwmon_temp_crit_hyst_celsius{instance=~\"$instance\"}, \"label\", \"$0\", \"sensor\", \".*\") \r\n    * on(instance,chip) group_left(chip_name) node_hwmon_chip_names\r\n    unless on(instance,chip,sensor) node_hwmon_sensor_label",
                        "instant": false,
                        "legendFormat": "Critical Hysteresis  {{ chip_name }}/{{ label }}",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "D"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
